# Chara self-host configuration — copy to .env and fill in.
# Never commit the resulting .env file.

# --- Required secrets ---
# Long random string used to sign JWTs. Generate with: openssl rand -base64 48
JWT_SECRET=

# Postgres password for the bundled database.
POSTGRES_PASSWORD=

# MinIO (S3-compatible storage) root credentials.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# --- Public URL ---
# The externally reachable base URL of this instance (used for magic links,
# deep links, and the instance descriptor). Defaults to http://localhost:8080.
BASE_URL=http://localhost:8080

# Host port the API listens on (container always serves on 8080).
API_PORT=8080

# --- Email (magic-link sign-in) ---
# Without SMTP configured, magic links are logged instead of emailed.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@chara.app

# --- OIDC (optional, self-hosted single sign-on) ---
# Point at your Authentik / Keycloak / Authelia issuer to enable OIDC login.
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# --- Android App Links (optional) ---
# SHA-256 of your Play App Signing key (Play Console → App integrity).
# Leave empty to fall back to the baked-in default.
ANDROID_PACKAGE_NAME=
ANDROID_CERT_FINGERPRINT=
