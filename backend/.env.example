# Server
ADDR=:8080
BASE_URL=http://localhost:8080

# CORS allowlist (comma-separated origins). When unset, defaults to the Expo
# dev server: http://localhost:8081 and http://localhost:19006. Add the
# production marketing/web origins here for hosted deploys.
# ALLOWED_CORS_ORIGINS=https://getchara.lovable.app,https://chara-api.lurkhuset.com

# Database
DATABASE_URL=postgres://chara:password@localhost:5432/chara?sslmode=disable

# Instance mode: "selfhost" or "hosted"
INSTANCE_MODE=selfhost

# JWT (HS256 for selfhost — minimum 32 characters)
JWT_SECRET=change-me-to-a-long-random-secret-32b

# JWT (RS256 for hosted — both private and public PEMs required)
# JWT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# DEV_MODE=true relaxes the email-provider requirement and returns the magic
# link token in /api/auth/magic-link's response body. **Must be false (unset)
# in hosted mode** — boot fails otherwise.
# DEV_MODE=false

# DEMO_LOGIN_EMAILS — comma-separated allowlist of addresses that receive
# their magic-link token inline in the /api/auth/magic-link response (like
# DEV_MODE) even in hosted mode, so app-store reviewers can sign into a
# pre-seeded demo account without inbox access. Every other address still
# goes through real email delivery. Keep this to dedicated demo accounts only.
# DEMO_LOGIN_EMAILS=appstore-review@getchara.app,playstore-review@getchara.app

# Magic link TTL (default 15m)
# MAGIC_LINK_TTL=15m

# Refresh token TTL — how long a user stays signed in without re-authenticating.
# The access JWT stays short (24h); the refresh token (default 1y) silently
# renews it. Revocable server-side (logout, account deletion, reuse detection).
# MAGIC_LINK_TTL-style duration string (e.g. 720h, 2160h, 8760h).
# REFRESH_TOKEN_TTL=8760h

# Email — choose one:
# Option A: SMTP (selfhost default)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=yourpassword
SMTP_FROM=noreply@example.com

# Option B: Resend (hosted)
# RESEND_API_KEY=re_...

# Storage (S3-compatible)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=chara
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# OIDC (selfhost only — optional)
# OIDC_ISSUER_URL=https://auth.example.com
# OIDC_CLIENT_ID=chara
# OIDC_CLIENT_SECRET=secret

# Push notifications (optional)
# EXPO_ACCESS_TOKEN=

# Protocol-version bounds (see multi-server-accounts-design spec §9, §19).
# MIN_APP_PROTOCOL=0 accepts legacy app builds that don't send the
# X-Chara-App-Protocol header. Bump to 1 only after the multi-server app
# build is broadly adopted.
# MIN_APP_PROTOCOL=0
# MAX_APP_PROTOCOL=2

# RECURRING_ENABLED — disable to turn off the recurring-expense scheduler
# and its HTTP routes. Default: true. Useful for self-hosters who don't want
# the background job system (River) running.
# RECURRING_ENABLED=true

# Hosted-only (leave blank for selfhost — requires INSTANCE_MODE=hosted to take effect)
# Google Sign In:
#   GOOGLE_CLIENT_ID     — use the **web** OAuth client ID, not the iOS one.
#                          The mobile app's @react-native-google-signin SDK is
#                          configured with this as `webClientId`, which means
#                          the returned ID token's `aud` claim is the web
#                          client — that's what the backend verifies against.
#                          This is the only value required to enable the
#                          native ID-token flow.
#   GOOGLE_CLIENT_SECRET — optional. Not used by the native flow; kept for the
#                          future server-side web OAuth code-exchange flow.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Apple Sign In:
#   APPLE_BUNDLE_ID — the app's bundle identifier; matches the `aud` claim Apple signs into the identity token
#   APPLE_TEAM_ID   — Apple developer team id (used by the future revoke flow)
#   APPLE_KEY_ID    — id of the Sign-in-with-Apple key (used by the future revoke flow)
#   APPLE_PRIVATE_KEY_PEM — PEM-encoded EC private key; leave blank for now, only needed for revoke flow
# APPLE_BUNDLE_ID=
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY_PEM=
