# Server
ADDR=:8080
BASE_URL=http://localhost:8080

# Database
DATABASE_URL=postgres://quits:password@localhost:5432/quits?sslmode=disable

# Instance mode: "selfhost" or "hosted"
INSTANCE_MODE=selfhost

# JWT (HS256 for selfhost)
JWT_SECRET=change-me-to-a-long-random-secret

# Magic link TTL (default 15m)
# MAGIC_LINK_TTL=15m

# Email — choose one:
# Option A: SMTP (selfhost default)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=yourpassword
SMTP_FROM=noreply@example.com

# Option B: Resend (hosted)
# RESEND_API_KEY=re_...

# Storage (S3-compatible)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=quits
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# OIDC (selfhost only — optional)
# OIDC_ISSUER_URL=https://auth.example.com
# OIDC_CLIENT_ID=quits
# OIDC_CLIENT_SECRET=secret

# Push notifications (optional)
# EXPO_ACCESS_TOKEN=

# Hosted-only (leave blank for selfhost)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# APPLE_BUNDLE_ID=
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY_PEM=
