# Server
ADDR=:8080
BASE_URL=http://localhost:8080

# Database
DATABASE_URL=postgres://chara:password@localhost:5432/chara?sslmode=disable

# Instance mode: "selfhost" or "hosted"
INSTANCE_MODE=selfhost

# JWT (HS256 for selfhost)
JWT_SECRET=change-me-to-a-long-random-secret

# Magic link TTL (default 15m)
# MAGIC_LINK_TTL=15m

# Email — choose one:
# Option A: SMTP (selfhost default)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=yourpassword
SMTP_FROM=noreply@example.com

# Option B: Resend (hosted)
# RESEND_API_KEY=re_...

# Storage (S3-compatible)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=chara
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# OIDC (selfhost only — optional)
# OIDC_ISSUER_URL=https://auth.example.com
# OIDC_CLIENT_ID=chara
# OIDC_CLIENT_SECRET=secret

# Push notifications (optional)
# EXPO_ACCESS_TOKEN=

# Protocol-version bounds (see multi-server-accounts-design spec §9, §19).
# MIN_APP_PROTOCOL=0 accepts legacy app builds that don't send the
# X-Chara-App-Protocol header. Bump to 1 only after the multi-server app
# build is broadly adopted.
# MIN_APP_PROTOCOL=0
# MAX_APP_PROTOCOL=2

# RECURRING_ENABLED — disable to turn off the recurring-expense scheduler
# and its HTTP routes. Default: true. Useful for self-hosters who don't want
# the background job system (River) running.
# RECURRING_ENABLED=true

# Hosted-only (leave blank for selfhost)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# APPLE_BUNDLE_ID=
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY_PEM=
